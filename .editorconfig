root = true

[*]
charset = utf-8
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true

# C / C++ / headers
[*.{c,cpp,h,hpp}]
indent_style = space
indent_size = 4

# JavaScript / JSON
[*.{js,mjs,cjs,json}]
indent_style = space
indent_size = 2

# YAML / config
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Markdown
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# INI / PlatformIO config
[*.ini]
indent_style = space
indent_size = 4

# CSV
[*.csv]
trim_trailing_whitespace = false
